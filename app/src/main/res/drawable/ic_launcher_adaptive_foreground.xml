<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#33000000" />
        </shape>
    </item>

    <item
        android:left="9dp"
        android:top="9dp"
        android:right="9dp"
        android:bottom="9dp">
        <shape android:shape="rectangle">
            <corners android:radius="25dp" />
            <solid android:color="#24FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#99FFFFFF" />
        </shape>
    </item>

    <item
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"
        android:drawable="@mipmap/ic_launcher_foreground" />

    <item
        android:left="15dp"
        android:top="15dp"
        android:right="15dp"
        android:bottom="59dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="270"
                android:startColor="#59FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
