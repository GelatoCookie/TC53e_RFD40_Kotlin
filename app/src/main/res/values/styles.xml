<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccentDark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surfaceColor</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="android:windowBackground">@color/screenBackground</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/colorPrimaryDark</item>
        <item name="materialButtonStyle">@style/Widget.AppTheme.PrimaryButton</item>
    </style>

    <style name="Widget.AppTheme.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextAppearance">@style/TextAppearance.AppTheme.ToolbarTitle</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.AppTheme.ToolbarSubtitle</item>
        <item name="titleTextColor">@color/textPrimary</item>
        <item name="subtitleTextColor">@color/textSecondary</item>
        <item name="navigationIconTint">@color/textPrimary</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="TextAppearance.AppTheme.ToolbarTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.AppTheme.ToolbarSubtitle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
    </style>

    <style name="Widget.AppTheme.SurfaceCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surfaceColor</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeColor">@color/cardStroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.AppTheme.Headline" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/heroTitle</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.AppTheme.BodyValue" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/heroTitle</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.AppTheme.StatusBadge" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:background">@drawable/bg_status_badge</item>
        <item name="android:paddingLeft">12dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingRight">12dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textColor">@color/statusText</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.AppTheme.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.AppTheme.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/secondaryButtonSurface</item>
        <item name="strokeColor">@color/cardStrokeStrong</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/colorAccentSoft</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.AppTheme.ListHeaderLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
